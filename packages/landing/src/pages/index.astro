---
import '../styles/global.css';
import OutlineDemo from '../components/OutlineDemo.svelte';

const installCommand = `npm install -g kalamu
kalamu init`;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Kalamu — repo-local task outliner for you and your agents</title>
		<meta
			name="description"
			content="A keyboard-first outliner that lives in your repository. Brainstorm in a fast web UI; your coding agents pick up the same tasks through a CLI built for them."
		/>
	</head>
	<body>
		<main>
			<section class="hero">
				<div class="hero-content">
					<h1>Think it, jot it, queue it for your agent</h1>
					<h2>
						Lightweight, local outliner application to put down your thoughts and turn them into tasks for your
						agents to execute.
					</h2>

					<div class="cta-row">
						<div class="install-block">
							<pre><code>{installCommand}</code></pre>
							<button id="copy-install" data-install={installCommand} aria-label="Copy install commands">
								<svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
									<rect x="5.5" y="5.5" width="8" height="8" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.3" />
									<path
										d="M3.5 10.5h-1a1 1 0 0 1-1-1v-7a1 1 0 0 1 1-1h7a1 1 0 0 1 1 1v1"
										fill="none"
										stroke="currentColor"
										stroke-width="1.3"
									/>
								</svg>
								<span>Copy</span>
							</button>
						</div>

						<a class="secondary-cta" href="#next-section">Read more ↓</a>
					</div>
				</div>

				<div class="hero-demo">
					<OutlineDemo client:load />
				</div>
			</section>

			<section id="next-section" aria-hidden="true"></section>
		</main>

		<script>
			const button = document.getElementById('copy-install') as HTMLButtonElement;
			const label = button.querySelector('span') as HTMLSpanElement;
			const original = label.textContent;
			let timer: ReturnType<typeof setTimeout> | undefined;
			button.addEventListener('click', async () => {
				try {
					await navigator.clipboard.writeText(button.dataset.install ?? '');
					label.textContent = 'Copied';
				} catch {
					label.textContent = 'Copy failed';
				}
				clearTimeout(timer);
				timer = setTimeout(() => (label.textContent = original), 2000);
			});
		</script>
	</body>
</html>

<style>
	main {
		max-width: 72rem;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.hero {
		min-height: 100vh;
		display: grid;
		grid-template-columns: 1fr 1fr;
		align-items: center;
		gap: 3rem;
		padding: 4rem 0;
	}

	.hero-content {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	h1 {
		font-size: clamp(2.25rem, 4vw, 3.25rem);
		line-height: 1.1;
		letter-spacing: -0.01em;
		font-weight: 700;
	}

	h2 {
		font-size: 1.15rem;
		font-weight: 400;
		line-height: 1.5;
		color: var(--muted);
		max-width: 34rem;
	}

	.cta-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 1.25rem;
		margin-top: 0.75rem;
	}

	.install-block {
		display: flex;
		align-items: stretch;
		border-radius: 8px;
		border: 1px solid var(--guide);
		background: var(--panel);
		overflow: hidden;
	}

	.install-block pre {
		margin: 0;
		padding: 0.85rem 1.1rem;
		font-size: 0.9rem;
		line-height: 1.6;
		white-space: pre;
	}

	#copy-install {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0 1rem;
		border: none;
		border-left: 1px solid var(--guide);
		background: color-mix(in srgb, var(--fg) 5%, transparent);
		color: var(--fg);
		font: inherit;
		font-size: 0.85rem;
		font-weight: 600;
		cursor: pointer;
	}

	#copy-install:hover {
		background: color-mix(in srgb, var(--fg) 9%, transparent);
	}

	.secondary-cta {
		font-size: 0.95rem;
		font-weight: 600;
		color: var(--fg);
		text-decoration: underline;
		text-decoration-color: color-mix(in srgb, var(--fg) 35%, transparent);
		text-underline-offset: 4px;
	}

	.secondary-cta:hover {
		text-decoration-color: currentColor;
	}

	.hero-demo {
		display: flex;
		justify-content: center;
	}

	@media (max-width: 900px) {
		.hero {
			grid-template-columns: 1fr;
			min-height: auto;
			padding: 3rem 0;
			gap: 2.5rem;
		}
	}
</style>
