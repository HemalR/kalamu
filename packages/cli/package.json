{
  "name": "kalamu",
  "version": "0.3.0",
  "description": "Repo-local outliner for turning developer thoughts into agent-ready tasks",
  "license": "MIT",
  "homepage": "https://kalamu.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hemalr/kalamu.git"
  },
